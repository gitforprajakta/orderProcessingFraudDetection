# ---------- Node / npm ----------
# If these were ever committed, run: git rm -r --cached node_modules cdk.out infra/dist
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------- AWS CDK / TypeScript ----------
# Synth output and asset zips — never commit (regenerate with `cdk synth`)
cdk.out/
.cdk.staging/
cdk.context.json
*.js.map
infra/dist/
infra/**/*.js
infra/**/*.d.ts
!infra/**/*.config.js
*.tsbuildinfo

# ---------- Vite / Frontend build ----------
frontend/dist/
frontend/.vite/
frontend/node_modules/

# ---------- Env / secrets ----------
.env
.env.*
!.env.example
.envrc
*.pem
*.key
aws-exports.js

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

